# Copy to backend/.env for local overrides (optional — defaults work for dev)
# Spring Boot maps these automatically via relaxed binding.

# --- Required in production ---
SPRING_PROFILES_ACTIVE=prod
GUESSIFY_DAILY_SECRET=change-me-to-a-long-random-string

# --- Production URLs (set after deploy) ---
GUESSIFY_FRONTEND_BASE_URL=http://localhost:5173
GUESSIFY_CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# --- Server ---
PORT=8080

# Generate a daily secret locally:
#   openssl rand -base64 48
